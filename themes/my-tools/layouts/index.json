{{- $index := slice -}}
{{- range where .Site.RegularPages "Section" "ne" "farmate" -}}
  {{- $index = $index | append (dict 
    "title" .Title 
    "content" (.Summary | plainify)
    "link" .RelPermalink 
    "date" (.Date.Format "02 Jan 2006")
    "image" (or .Params.imageBanner "/default.png")
  ) -}}
{{- end -}}
{{ $index | jsonify }}