      <description>&lt;!DOCTYPE html&gt;&#xD;&#xA;&lt;html lang=&#34;en&#34;&gt;&#xD;&#xA;&lt;head&gt;&#xD;&#xA;&lt;meta charset=&#34;UTF-8&#34;&gt;&#xD;&#xA;&lt;meta name=&#34;viewport&#34; content=&#34;width=device-width, initial-scale=1.0&#34;&gt;&#xD;&#xA;&lt;title&gt;Resume&lt;/title&gt;&#xD;&#xA;&lt;script src=&#34;https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js&#34;&gt;&lt;/script&gt;&#xD;&#xA;&lt;script src=&#34;https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js&#34;&gt;&lt;/script&gt;&#xD;&#xA;&lt;script src=&#34;https://unpkg.com/html2pdf.js@0.10.1/dist/html2pdf.bundle.min.js&#34;&gt;&lt;/script&gt;&#xD;&#xA;&lt;style&gt;&#xD;&#xA;&#xD;&#xA;.resume{&#xD;&#xA;    max-width:900px;&#xD;&#xA;    margin:auto;&#xD;&#xA;    background:#fff;&#xD;&#xA;    padding:25px;&#xD;&#xA;    padding-bottom:40px; /* extra bottom space */&#xD;&#xA;    border:1px solid #000;&#xD;&#xA;}&#xD;&#xA;.title{&#xD;&#xA;text-align:center;&#xD;&#xA;font-size:28px;&#xD;&#xA;font-weight:bold;&#xD;&#xA;text-decoration:underline;&#xD;&#xA;margin-bottom:20px;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.resume-header{&#xD;&#xA;display:flex;&#xD;&#xA;justify-content:space-between;&#xD;&#xA;align-items:flex-start;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.info{&#xD;&#xA; font-weight:bold;&#xD;&#xA;line-height:1.5;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.photo{&#xD;&#xA;width:100px;&#xD;&#xA;height:120px;&#xD;&#xA;border:1px solid #000;&#xD;&#xA;object-fit:cover;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.resume-section{&#xD;&#xA;margin-top:20px;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.resume-section h3{&#xD;&#xA;border-bottom:1px solid #000;&#xD;&#xA;padding-bottom:5px;&#xD;&#xA;margin-bottom:10px;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;table{&#xD;&#xA;width:100%;&#xD;&#xA;border-collapse:collapse;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;table th,&#xD;&#xA;table td{&#xD;&#xA;border:1px solid #000;&#xD;&#xA;padding:8px;&#xD;&#xA;text-align:center;&#xD;&#xA;}&#xD;&#xA;.personal {border: none;}&#xD;&#xA;.personal td{&#xD;&#xA;border:none;&#xD;&#xA;text-align:left;&#xD;&#xA;padding:5px;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.signature{&#xD;&#xA;margin-top:40px;&#xD;&#xA;text-align:right;&#xD;&#xA;font-weight:bold;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.print-btn{&#xD;&#xA;display:block;&#xD;&#xA;margin:20px auto;&#xD;&#xA;padding:12px 25px;&#xD;&#xA;font-size:18px;&#xD;&#xA;cursor:pointer;&#xD;&#xA;}&#xD;&#xA;.resume-footer{&#xD;&#xA;    display:flex;&#xD;&#xA;    justify-content:space-between;&#xD;&#xA;    align-items:flex-start;&#xD;&#xA;    margin-top:20px;&#xD;&#xA;    width:100%;&#xD;&#xA;  page-break-inside: avoid;&#xD;&#xA;    break-inside: avoid;&#xD;&#xA;}&#xD;&#xA;hr{&#xD;&#xA;    border:none;&#xD;&#xA;    border-top:1px dotted #000;&#xD;&#xA;    margin:15px 0;&#xD;&#xA;}&#xD;&#xA;.resume-footer .left{&#xD;&#xA;    text-align:left;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.resume-footer .right{&#xD;&#xA;    text-align:center;&#xD;&#xA;    min-width:180px;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.resume-footer .left,&#xD;&#xA;.resume-footer .right{&#xD;&#xA;    page-break-inside: avoid;&#xD;&#xA;    break-inside: avoid;&#xD;&#xA;}&#xD;&#xA;.pdf-mode{&#xD;&#xA;    max-width:100% !important;&#xD;&#xA;    border:none !important;&#xD;&#xA;    background:#fff !important;&#xD;&#xA;    padding:5px !important;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.pdf-mode .action-buttons{&#xD;&#xA;    display:none !important;&#xD;&#xA;}&#xD;&#xA;@media print {&#xD;&#xA;&#xD;&#xA;       @page{&#xD;&#xA;        size:A4;&#xD;&#xA;        margin:12mm;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;    body{&#xD;&#xA;        background:#fff;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    .resume{&#xD;&#xA;        width:100%;&#xD;&#xA;        border:none;&#xD;&#xA;        padding-bottom:20mm; /* bottom margin */&#xD;&#xA;        page-break-after:auto;&#xD;&#xA;        padding:25px 25px 40px;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;   &#xD;&#xA;   .resume-footer{&#xD;&#xA;        page-break-before: auto;&#xD;&#xA;        page-break-inside: avoid;&#xD;&#xA;        break-inside: avoid;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    .resume-section{&#xD;&#xA;        page-break-inside: avoid;&#xD;&#xA;        break-inside: avoid;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;  &#xD;&#xA;  .action-buttons{&#xD;&#xA;    display:flex;&#xD;&#xA;    gap:10px;&#xD;&#xA;    justify-content:center;&#xD;&#xA;    flex-wrap:wrap;&#xD;&#xA;    margin-bottom:20px;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.action-buttons button{&#xD;&#xA;    padding:10px 18px;&#xD;&#xA;    border:none;&#xD;&#xA;    background:#0d6efd;&#xD;&#xA;    color:#fff;&#xD;&#xA;    cursor:pointer;&#xD;&#xA;    border-radius:5px;&#xD;&#xA;    font-size:15px;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.action-buttons button:hover{&#xD;&#xA;    opacity:.9;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;@media print{&#xD;&#xA;    .action-buttons{&#xD;&#xA;        display:none;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&lt;/style&gt;&#xD;&#xA;&lt;/head&gt;&#xD;&#xA;&lt;body&gt;&#xD;&#xA;&#xD;&#xA;&lt;div class=&#34;action-buttons&#34;&gt;&#xD;&#xA;&#xD;&#xA;  &lt;button onclick=&#34;printResume()&#34;&gt;🖨️ Print &lt;/button&gt;&#xD;&#xA;&#xD;&#xA;    &lt;button onclick=&#34;savePDF()&#34;&gt;&#xD;&#xA;        📄 Save PDF&#xD;&#xA;    &lt;/button&gt;&#xD;&#xA;&#xD;&#xA;    &lt;button onclick=&#34;saveImage()&#34;&gt;&#xD;&#xA;        🖼️ Save Image&#xD;&#xA;    &lt;/button&gt;&#xD;&#xA;&#xD;&#xA;    &lt;button onclick=&#34;editResume()&#34;&gt;&#xD;&#xA;        ✏️ Edit Resume&#xD;&#xA;    &lt;/button&gt;&#xD;&#xA;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;div class=&#34;resume&#34;&gt;&#xD;&#xA;&#xD;&#xA;    &lt;div class=&#34;title&#34; id=&#34;resumeType&#34;&gt;&#xD;&#xA;        Resume&#xD;&#xA;    &lt;/div&gt;&#xD;&#xA;&#xD;&#xA;    &lt;!-- Header --&gt;&#xD;&#xA;&#xD;&#xA;    &lt;div class=&#34;resume-header&#34;&gt;&#xD;&#xA;&#xD;&#xA;        &lt;div class=&#34;info&#34;&gt;&#xD;&#xA;&#xD;&#xA;           &lt;div class=&#34;profile-info&#34;&gt;&#xD;&#xA;            &lt;h4  id=&#34;r_name&#34;&gt; &lt;/h4&gt;&lt;br&gt;&#xD;&#xA;            &lt;span id =&#34;r_address&#34;&gt; &lt;/span&gt;&lt;br&gt;&#xD;&#xA;             &lt;b&gt;Contact No.&lt;/b&gt;: &lt;span id=&#34;r_mobile&#34;&gt; &lt;/span&gt;&lt;br&gt;&#xD;&#xA;             &lt;b&gt;Email ID&lt;/b&gt;: &lt;span id=&#34;r_email&#34;&gt; &lt;/span&gt;&#xD;&#xA;        &lt;/div&gt;&#xD;&#xA;&#xD;&#xA;        &lt;/div&gt; &#xD;&#xA;&#xD;&#xA;        &lt;img&#xD;&#xA;            id=&#34;r_photo&#34;&#xD;&#xA;            class=&#34;photo&#34;&#xD;&#xA;            src=&#34;&#34;&#xD;&#xA;            alt=&#34;Photo&#34;&#xD;&#xA;        &gt;&#xD;&#xA;&#xD;&#xA;    &lt;/div&gt;&lt;hr&gt;&#xD;&#xA;&#xD;&#xA;    &lt;!-- Career Objective --&gt;&#xD;&#xA;&#xD;&#xA;    &lt;div class=&#34;resume-section&#34;&gt;&#xD;&#xA;&#xD;&#xA;        &lt;h3&gt;Career Objective&lt;/h3&gt;&#xD;&#xA;&#xD;&#xA;        &lt;p id=&#34;r_objective&#34;&gt;&lt;/p&gt;</description>
