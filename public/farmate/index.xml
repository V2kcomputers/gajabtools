      <guid>http://localhost:1313/matrimonial-biodata/</guid>
      <description>&lt;!DOCTYPE html&gt;&#xD;&#xA;&lt;html lang=&#34;en&#34;&gt;&#xD;&#xA;&lt;head&gt;&#xD;&#xA;&lt;meta charset=&#34;UTF-8&#34;&gt;&#xD;&#xA;&lt;meta name=&#34;viewport&#34; content=&#34;width=device-width, initial-scale=1.0&#34;&gt;&#xD;&#xA;&lt;title&gt;Matrimonial Biodata&lt;/title&gt;&#xD;&#xA;&#xD;&#xA;&lt;link href=&#34;https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&amp;display=swap&#34; rel=&#34;stylesheet&#34;&gt;&#xD;&#xA;&#xD;&#xA;&lt;style&gt;&#xD;&#xA;.hero-section{&#xD;&#xA;    display:flex;&#xD;&#xA;    gap:35px;&#xD;&#xA;    align-items:center;&#xD;&#xA;    margin-bottom:35px;&#xD;&#xA;    padding:25px;&#xD;&#xA;    background:linear-gradient(&#xD;&#xA;        135deg,&#xD;&#xA;        #fffef9,&#xD;&#xA;        #f5ead0&#xD;&#xA;    );&#xD;&#xA;    border:2px solid #d8bc73;&#xD;&#xA;    border-radius:20px;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.profile-photo{&#xD;&#xA;    width:220px;&#xD;&#xA;    height:280px;&#xD;&#xA;    flex-shrink:0;&#xD;&#xA;    overflow:hidden;&#xD;&#xA;    border-radius:16px;&#xD;&#xA;    border:4px solid #b8943d;&#xD;&#xA;    box-shadow:0 10px 25px rgba(0,0,0,.15);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.profile-photo img{&#xD;&#xA;    width:100%;&#xD;&#xA;    height:100%;&#xD;&#xA;    object-fit:cover;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.hero-info{&#xD;&#xA;    flex:1;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.hero-info h1{&#xD;&#xA;    font-size:48px;&#xD;&#xA;    color:#7a5b15;&#xD;&#xA;    margin-bottom:20px;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.hero-grid{&#xD;&#xA;    display:grid;&#xD;&#xA;    grid-template-columns:220px 1fr;&#xD;&#xA;    gap:12px 25px;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.biodata-section{&#xD;&#xA;    margin-top:25px;&#xD;&#xA;    padding:25px;&#xD;&#xA;    background:#fff;&#xD;&#xA;    border-radius:18px;&#xD;&#xA;    border:1px solid #ead9aa;&#xD;&#xA;    box-shadow:0 4px 15px rgba(0,0,0,.05);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.section-title{&#xD;&#xA;    color:#b38a24;&#xD;&#xA;    font-size:28px;&#xD;&#xA;    font-weight:700;&#xD;&#xA;    margin-bottom:18px;&#xD;&#xA;    border-bottom:2px solid #ead9aa;&#xD;&#xA;    padding-bottom:10px;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.info-grid{&#xD;&#xA;    display:grid;&#xD;&#xA;    grid-template-columns:240px 1fr;&#xD;&#xA;    gap:12px 25px;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.label{&#xD;&#xA;    font-weight:700;&#xD;&#xA;    color:#7a5b15;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.value{&#xD;&#xA;    color:#333;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.about{&#xD;&#xA;    line-height:1.9;&#xD;&#xA;    font-size:18px;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;.biodata-footer{&#xD;&#xA;    margin-top:35px;&#xD;&#xA;    text-align:center;&#xD;&#xA;    color:#888;&#xD;&#xA;    font-size:14px;&#xD;&#xA;}&#xD;&#xA;&lt;/style&gt;&#xD;&#xA;&lt;/head&gt;&#xD;&#xA;&lt;body&gt;&#xD;&#xA;&#xD;&#xA;&lt;div class=&#34;biodata&#34;&gt;&#xD;&#xA;&#xD;&#xA;    &lt;!-- Header --&gt;&#xD;&#xA;&#xD;&#xA;    &lt;div class=&#34;hero-section&#34;&gt;&#xD;&#xA;&#xD;&#xA;        &lt;div class=&#34;profile-photo&#34;&gt;&#xD;&#xA;            &lt;img id=&#34;photo&#34; src=&#34;&#34; alt=&#34;Photo&#34;&gt;&#xD;&#xA;        &lt;/div&gt;&#xD;&#xA;&#xD;&#xA;        &lt;div class=&#34;hero-info&#34;&gt;&#xD;&#xA;&#xD;&#xA;            &lt;h1 id=&#34;fullName&#34;&gt;&lt;/h1&gt;&#xD;&#xA;&#xD;&#xA;            &lt;div&#xD;&#xA;                id=&#34;basicInfo&#34;&#xD;&#xA;                class=&#34;hero-grid&#34;&gt;&#xD;&#xA;            &lt;/div&gt;&#xD;&#xA;&#xD;&#xA;        &lt;/div&gt;&#xD;&#xA;&#xD;&#xA;    &lt;/div&gt;&#xD;&#xA;&#xD;&#xA;    &lt;!-- About --&gt;&#xD;&#xA;&#xD;&#xA;    &lt;div class=&#34;biodata-section&#34;&gt;&#xD;&#xA;&#xD;&#xA;        &lt;div class=&#34;section-title&#34;&gt;&#xD;&#xA;            About Me&#xD;&#xA;        &lt;/div&gt;&#xD;&#xA;&#xD;&#xA;        &lt;div&#xD;&#xA;            class=&#34;about&#34;&#xD;&#xA;            id=&#34;about&#34;&gt;&#xD;&#xA;        &lt;/div&gt;&#xD;&#xA;&#xD;&#xA;    &lt;/div&gt;&#xD;&#xA;&#xD;&#xA;    &lt;!-- Personal --&gt;&#xD;&#xA;&#xD;&#xA;    &lt;div class=&#34;biodata-section&#34;&gt;&#xD;&#xA;&#xD;&#xA;        &lt;div class=&#34;section-title&#34;&gt;&#xD;&#xA;            Personal Details&#xD;&#xA;        &lt;/div&gt;&#xD;&#xA;&#xD;&#xA;        &lt;div&#xD;&#xA;            id=&#34;personalInfo&#34;&#xD;&#xA;            class=&#34;info-grid&#34;&gt;&#xD;&#xA;        &lt;/div&gt;&#xD;&#xA;&#xD;&#xA;    &lt;/div&gt;&#xD;&#xA;&#xD;&#xA;    &lt;!-- Family --&gt;&#xD;&#xA;&#xD;&#xA;    &lt;div class=&#34;biodata-section&#34;&gt;&#xD;&#xA;&#xD;&#xA;        &lt;div class=&#34;section-title&#34;&gt;&#xD;&#xA;            Family Details&#xD;&#xA;        &lt;/div&gt;&#xD;&#xA;&#xD;&#xA;        &lt;div&#xD;&#xA;            id=&#34;familyInfo&#34;&#xD;&#xA;            class=&#34;info-grid&#34;&gt;&#xD;&#xA;        &lt;/div&gt;&#xD;&#xA;&#xD;&#xA;    &lt;/div&gt;&#xD;&#xA;&#xD;&#xA;    &lt;!-- Contact --&gt;&#xD;&#xA;&#xD;&#xA;    &lt;div class=&#34;biodata-section&#34;&gt;&#xD;&#xA;&#xD;&#xA;        &lt;div class=&#34;section-title&#34;&gt;&#xD;&#xA;            Contact Details&#xD;&#xA;        &lt;/div&gt;&#xD;&#xA;&#xD;&#xA;        &lt;div&#xD;&#xA;            id=&#34;contactInfo&#34;&#xD;&#xA;            class=&#34;info-grid&#34;&gt;&#xD;&#xA;        &lt;/div&gt;&#xD;&#xA;&#xD;&#xA;    &lt;/div&gt;&#xD;&#xA;&#xD;&#xA;    &lt;div class=&#34;biodata-footer&#34;&gt;&#xD;&#xA;        Matrimonial Biodata&#xD;&#xA;    &lt;/div&gt;&#xD;&#xA;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&#xD;&#xA;&lt;script&gt;&#xD;&#xA;// Complete Biodata JavaScript&#xD;&#xA;&#xD;&#xA;async function openDB(){&#xD;&#xA;    return new Promise((resolve,reject)=&gt;{&#xD;&#xA;        const request = indexedDB.open(&#34;BiodataDB&#34;, 2);&#xD;&#xA;        request.onsuccess = ()=&gt;resolve(request.result);&#xD;&#xA;        request.onerror = ()=&gt;reject(request.error);&#xD;&#xA;    });&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;async function getPhoto(photoId){&#xD;&#xA;    const db = await openDB();&#xD;&#xA;&#xD;&#xA;    return new Promise((resolve,reject)=&gt;{&#xD;&#xA;        const tx = db.transaction(&#34;photos&#34;,&#34;readonly&#34;);&#xD;&#xA;        const request = tx.objectStore(&#34;photos&#34;).get(photoId);&#xD;&#xA;&#xD;&#xA;        request.onsuccess = ()=&gt;resolve(request.result?.file);&#xD;&#xA;        request.onerror = ()=&gt;reject(request.error);&#xD;&#xA;    });&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;const token = new URLSearchParams(location.search).get(&#34;token&#34;);&#xD;&#xA;const data = JSON.parse(localStorage.getItem(token));&#xD;&#xA;&#xD;&#xA;function renderSection(containerId, fields){&#xD;&#xA;    const container = document.getElementById(containerId);&#xD;&#xA;    if(!container || !fields) return;&#xD;&#xA;&#xD;&#xA;    container.innerHTML = &#34;&#34;;&#xD;&#xA;&#xD;&#xA;    fields.forEach(field=&gt;{&#xD;&#xA;        const label = document.createElement(&#34;div&#34;);&#xD;&#xA;        label.className = &#34;label&#34;;&#xD;&#xA;        label.textContent = field.label;&#xD;&#xA;&#xD;&#xA;        const value = document.createElement(&#34;div&#34;);&#xD;&#xA;        value.className = &#34;value&#34;;&#xD;&#xA;        value.textContent = field.value;&#xD;&#xA;&#xD;&#xA;        container.append(label,value);&#xD;&#xA;    });&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if(data){&#xD;&#xA;    const fullName = document.getElementById(&#34;fullName&#34;);&#xD;&#xA;    if(fullName) fullName.textContent = data.fullName || &#34;&#34;;&#xD;&#xA;&#xD;&#xA;    const about = document.getElementById(&#34;about&#34;);&#xD;&#xA;    if(about) about.textContent = data.about || &#34;&#34;;&#xD;&#xA;&#xD;&#xA;    renderSection(&#34;basicInfo&#34;, data.sections?.basicInfo);&#xD;&#xA;    renderSection(&#34;personalInfo&#34;, data.sections?.personalInfo);&#xD;&#xA;    renderSection(&#34;familyInfo&#34;, data.sections?.familyInfo);&#xD;&#xA;    renderSection(&#34;contactInfo&#34;, data.sections?.contactInfo);&#xD;&#xA;    renderSection(&#34;educationInfo&#34;, data.sections?.educationInfo);&#xD;&#xA;&#xD;&#xA;    (async()=&gt;{&#xD;&#xA;        if(data.photoId){&#xD;&#xA;            try{&#xD;&#xA;                const file = await getPhoto(data.photoId);&#xD;&#xA;                if(file){&#xD;&#xA;                    document.getElementById(&#34;photo&#34;).src =&#xD;&#xA;                        URL.createObjectURL(file);&#xD;&#xA;                }&#xD;&#xA;            }catch(err){&#xD;&#xA;                console.error(err);&#xD;&#xA;            }&#xD;&#xA;        }&#xD;&#xA;    })();&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&lt;/script&gt;&#xD;&#xA;&#xD;&#xA;&lt;/body&gt;&#xD;&#xA;&lt;/html&gt;</description>
    </item>
